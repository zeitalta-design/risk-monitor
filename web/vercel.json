{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/auto-sync",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/watchlist-notify",
      "schedule": "0 19 * * 1"
    },
    {
      "path": "/api/cron/notify-deal-score/realtime",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/notify-deal-score/daily",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/notify-saved-deals",
      "schedule": "0 23 * * *"
    }
  ]
}
